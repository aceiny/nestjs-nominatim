{
  "name": "nestjs-nominatim",
  "version": "2.0.1",
  "description": "A powerful NestJS module for OpenStreetMap Nominatim API integration — geocoding, reverse geocoding, place lookup, and built-in caching with full TypeScript support",
  "author": "Yassine Zeraibi <aceiny.dev@gmail.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "npm run build && node dist/test.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aceiny/nestjs-nominatim.git"
  },
  "bugs": {
    "url": "https://github.com/aceiny/nestjs-nominatim/issues"
  },
  "homepage": "https://github.com/aceiny/nestjs-nominatim#readme",
  "keywords": [
    "nestjs",
    "nominatim",
    "geocoding",
    "reverse-geocoding",
    "openstreetmap",
    "osm",
    "geolocation",
    "address-lookup",
    "nestjs-module",
    "typescript",
    "caching"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "axios": "^1.11.0",
    "cache-manager": "^7.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/cache-manager": {
      "optional": true
    },
    "cache-manager": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  }
}
